{
  "$schema": "./config.schema.json",
  "_comment": "fetch-archive skill 配置文件。首次使用时粘贴知识库链接即可自动完成配置，也可手动编辑。",
  "_initialized": false,

  "lexiang": {
    "_comment": "乐享知识库配置。用于文章/视频/播客的归档转存。",

    "target_space": {
      "_comment": "目标知识库信息。从用户粘贴的知识库链接中自动解析填充。",
      "space_id": "",
      "space_name": "",
      "company_from": ""
    },

    "access_domain": {
      "_comment": "乐享前端域名。从用户粘贴的知识库链接中自动解析填充，适配自定义域名。",
      "domain": "lexiangla.com",
      "page_url_template": "https://lexiangla.com/pages/{entry_id}",
      "space_url_template": "https://lexiangla.com/spaces/{space_id}?company_from={company_from}"
    }
  }
}
